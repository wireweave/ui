{
  "name": "@wireweave/ui",
  "version": "0.4.0",
  "type": "module",
  "description": "Wireweave UI - React component design system shared across Wireweave dashboard, admin, and tooling.",
  "license": "MIT",
  "author": "Wireweave",
  "homepage": "https://ui.wireweave.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wireweave/ui.git"
  },
  "bugs": {
    "url": "https://github.com/wireweave/ui/issues"
  },
  "keywords": [
    "wireweave",
    "design-system",
    "react",
    "tailwindcss",
    "radix-ui",
    "ui-components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./spec": {
      "types": "./dist/types/spec/index.d.ts",
      "import": "./dist/spec.js",
      "require": "./dist/spec.cjs"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./styles": "./dist/ui.css",
    "./styles.css": "./dist/ui.css",
    "./styles/theme": "./src/styles/theme.css",
    "./styles/theme.css": "./src/styles/theme.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src/styles/theme.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0",
    "release": "release-it",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "tailwind-merge": "^3.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "release-it": "^19.2.3",
    "storybook": "^8.6.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0"
  }
}
